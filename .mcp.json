{
  "mcpServers": {
    "hedera-docs": {
      "type": "http",
      "url": "https://docs.hedera.com/mcp"
    },
    "coolify": {
      "command": "npx",
      "args": ["-y", "coolify-mcp"],
      "env": {
        "COOLIFY_API_URL": "${COOLIFY_API_URL}",
        "COOLIFY_API_TOKEN": "${COOLIFY_API_TOKEN}"
      }
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "drawio": {
      "command": "npx",
      "args": ["-y", "drawio-mcp"]
    },
    "figma": {
      "command": "npx",
      "args": ["-y", "figma-developer-mcp", "--figma-api-key=${FIGMA_API_KEY}"]
    },
    "docker": {
      "command": "docker",
      "args": ["mcp", "gateway", "run"],
      "type": "stdio"
    },
    "maven-central": {
      "command": "npx",
      "args": ["mcp-maven-deps"],
      "type": "stdio"
    }
  }
}